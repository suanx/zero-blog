{
  "name": "zero-blog",
  "buildCommand": "npm run build",
  "outputDir": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "envVars": [
    {
      "key": "TURSO_DATABASE_URL",
      "type": "secret"
    },
    {
      "key": "TURSO_AUTH_TOKEN",
      "type": "secret"
    },
    {
      "key": "ADMIN_TOKEN",
      "type": "secret"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "source": "app",
    "include": ["api/**"],
    "maxDuration": 30
  }
}
